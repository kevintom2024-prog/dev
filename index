<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head><title>Student App</title></head>
<body>

  <h2>Add Student</h2>
  <form th:action="@{/save}" th:object="${student}" method="post">
    Name: <input type="text" th:field="*{name}"/> <br/>
    Dept: <input type="text" th:field="*{department}"/> <br/>
    <button type="submit">Save</button>
  </form>

  <h2>Student List</h2>
  <table border="1">
    <tr><th>ID</th><th>Name</th><th>Department</th><th>Action</th></tr>
    <tr th:each="s : ${students}">
      <td th:text="${s.id}"></td>
      <td th:text="${s.name}"></td>
      <td th:text="${s.department}"></td>
      <td><a th:href="@{/delete/{id}(id=${s.id})}">Delete</a></td>
    </tr>
  </table>

</body>
</html>
